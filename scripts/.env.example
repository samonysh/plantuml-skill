# plantuml-skill release configuration
# Copy to .env (or export in your shell) and override as needed.
# release.py reads these at startup; see scripts/release.py for the resolution
# order. Tokens are NOT stored here - rely on `gh auth login` / `clawhub login`
# or the CLIs' own env vars (GH_TOKEN, etc.).

# GitHub repository in OWNER/REPO form (used for gh release + clawhub --source-repo)
PLANTUML_RELEASE_GH_REPO=samonysh/plantuml-skill

# Main branch name to push version-bump commits to
PLANTUML_RELEASE_MAIN_BRANCH=main

# Git remote to push to
PLANTUML_RELEASE_REMOTE=origin

# ClawHub skill slug
PLANTUML_RELEASE_CLAWHUB_SLUG=plantuml-skill

# Archive base name (final file: <ARCHIVE_NAME>-v<version>.tar.gz)
PLANTUML_RELEASE_ARCHIVE_NAME=plantuml-skill

# Where to drop the built tar.gz (also where gh release uploads from)
PLANTUML_RELEASE_DIST_DIR=dist
